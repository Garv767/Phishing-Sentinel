{
  "manifest_version": 3,
  "name": "Sentinel Suite: Phishing Guardian",
  "version": "0.2.0",
  "description": "Real-time AI-driven visual spoofing detection.",
  "key": "",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://phishing-sentinel-api-service.onrender.com/*",
    "http://phishing-sentinel.onrender.com/*",
    "https://phishing-sentinel.netlify.app/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "externally_connectable": {
    "matches": [
      "https://phishing-sentinel.netlify.app/*",
      "http://localhost:5173/*"
    ]
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "http://localhost:5173/*",
        "https://phishing-sentinel.netlify.app/*"
      ],
      "js": ["src/content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "images/phishingSentinelLogo_16.png",
    "32": "images/phishingSentinelLogo_32.png",
    "48": "images/phishingSentinelLogo_48.png",
    "128": "images/phishingSentinelLogo_128.png"
  },
  "web_accessible_resources": [  
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"] 
    }
  ]
}